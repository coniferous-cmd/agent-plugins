#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).parent))
from todo_board import database_path, connect_database, project_path, push

parser = argparse.ArgumentParser(description="Add a task to a project")
parser.add_argument("project")
parser.add_argument("title")
parser.add_argument("-d", "--detail", default="")
parser.add_argument("-p", "--priority", type=int, default=0)
args = parser.parse_args()
directory = project_path()
connection = connect_database(database_path(directory))
try:
    push(connection, args.project, directory, args.title, args.detail, args.priority)
finally:
    connection.close()
