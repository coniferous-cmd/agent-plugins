#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).parent))
from todo_board import database_path, connect_database, list_tasks, print_task, project_path

parser = argparse.ArgumentParser(description="List incomplete tasks for a project")
parser.add_argument("project")
args = parser.parse_args()
directory = project_path()
connection = connect_database(database_path(directory))
try:
    for task in list_tasks(connection, args.project):
        print_task(task)
finally:
    connection.close()
