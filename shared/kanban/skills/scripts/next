#!/usr/bin/env python3
import argparse
import os
import sqlite3
import sys
from pathlib import Path


def database_path():
    override = os.environ.get("CODEX_DATA_DIR")
    if override:
        root = Path(override).expanduser()
    elif sys.platform == "darwin":
        root = Path.home() / "Library" / "Application Support" / "Codex"
    elif os.name == "nt":
        root = Path(os.environ.get("LOCALAPPDATA", Path.home() / "AppData/Local")) / "Codex"
    else:
        root = Path(os.environ.get("XDG_DATA_HOME", "~/.local/share")).expanduser() / "codex"
    return root / "projects" / "todo-board.db"


parser = argparse.ArgumentParser(description="Complete the next task for a project")
parser.add_argument("project")
args = parser.parse_args()
path = database_path()
if not path.exists():
    raise SystemExit(0)

with sqlite3.connect(path) as connection:
    task = connection.execute(
        """SELECT task.id, task.title, task.detail FROM task
           JOIN project ON project.id = task.project_id
           WHERE project.name = ?
           ORDER BY task.priority DESC, task.created_at ASC, task.id ASC LIMIT 1""",
        (args.project,),
    ).fetchone()
    if task is not None:
        connection.execute("DELETE FROM task WHERE id = ?", (task[0],))
        print(task[1])
        if task[2]:
            print(task[2])
